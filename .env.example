# These are set in the Vercel dashboard (Project → Settings → Environment Variables),
# NOT committed to git. This file just documents the two variables you need.

# The password users type on the login screen.
ACCESS_PASSWORD=change-me

# A long random secret — the value stored in the session cookie. Generate one with:
#   openssl rand -hex 32
# Treat it like a password. If you rotate it, everyone is signed out.
SESSION_TOKEN=replace-with-a-long-random-string
